# ROGUE Environment Configuration
# Copy to .env and fill in your values
# cp .env.example .env

# ─── OLLAMA ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=phi3:mini
OLLAMA_VISION_MODEL=llava
OLLAMA_CHAT_MODEL=mistral

# ─── WHISPER ─────────────────────────────────────────────────────────────────
WHISPER_BIN=~/whisper.cpp/main
WHISPER_MODEL=~/whisper.cpp/models/ggml-base.en.bin
WHISPER_LANGUAGE=en

# ─── PIPER TTS ───────────────────────────────────────────────────────────────
PIPER_BIN=~/piper/piper
PIPER_VOICE=~/piper/voices/en_US-lessac-medium.onnx

# ─── ROGUE OVERLAY ───────────────────────────────────────────────────────────
OVERLAY_HOTKEY=ctrl+space
OVERLAY_OPACITY=0.92
OVERLAY_ALWAYS_ON_TOP=true
OVERLAY_ENABLE=false

# ─── SCREEN CAPTURE ──────────────────────────────────────────────────────────
SCREEN_CAPTURE_ENABLE=true
SCREEN_CAPTURE_MONITOR=1

# ─── AUDIO SERVER (ESP32 stream receiver) ────────────────────────────────────
AUDIO_SERVER_HOST=0.0.0.0
AUDIO_SERVER_PORT=8765
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# ─── TAILSCALE / NETWORK ─────────────────────────────────────────────────────
# Ubuntu Tailscale IP (for ESP32 firmware to connect to)
UBUNTU_TAILSCALE_IP=100.x.x.x
UBUNTU_LOCAL_IP=192.168.x.x

# ─── AZ SYSTEM ───────────────────────────────────────────────────────────────
AZ_MODE=local
AZ_TENANT_ID=zpo
AZ_SECURE_SESSION=false

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
